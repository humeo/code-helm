# Advanced / dev-only overrides for CodeHelm.
# Normal setup should use:
#   code-helm onboard

CODE_HELM_CONFIG=~/.config/code-helm/config.toml
CODE_HELM_SECRETS=~/.config/code-helm/secrets.toml
CODE_HELM_DATABASE_PATH=~/.local/share/code-helm/codehelm.sqlite

# Optional runtime overrides
CODE_HELM_DISCORD_BOT_TOKEN=
CODE_HELM_DISCORD_GUILD_ID=
CODE_HELM_DISCORD_CONTROL_CHANNEL_ID=
CODE_HELM_CODEX_APP_SERVER_URL=ws://127.0.0.1:4123
